<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="BrkFileDialogWindow" parent="GtkWindow">
    <property name="modal">true</property>
    <property name="destroy-with-parent">true</property>
    <property name="default-width">640</property>
    <property name="default-height">480</property>

    <child>
      <object class="BrkToolbarView" id="toolbar_view">
        <child type="top">
          <object class="BrkToolbar">
            <child>
              <object class="BrkButtonGroup" id="quick_open_button_group">
                <child>
                  <object class="GtkToggleButton" id="quick_open_view_toggle">
                    <property name="action-name">dialog.quick-open</property>
                    <property name="icon-name">edit-find</property>
                    <property name="tooltip-text">Toggle search (automatic on text input)</property>
                  </object>
                </child>
                <child>
                  <object class="BrkQuickOpenEntry" id="quick_open_entry">
                    <property name="hexpand">true</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="BrkFileDialogPathBar" id="path_bar">
                <property name="hexpand">true</property>
              </object>
            </child>
            <child>
              <object class="BrkButtonGroup" id="view_button_group">
                <child>
                  <object class="GtkToggleButton" id="icon_view_toggle">
                    <property name="action-name">dialog.view-mode</property>
                    <property name="action-target">&apos;icon&apos;</property>
                    <property name="icon-name">view-grid</property>
                    <property name="tooltip-text">Grid view</property>
                  </object>
                </child>
                <child>
                  <object class="GtkToggleButton" id="list_view_toggle">
                    <property name="action-name">dialog.view-mode</property>
                    <property name="action-target">&apos;list&apos;</property>
                    <property name="icon-name">view-list</property>
                    <property name="tooltip-text">List view</property>
                  </object>
                </child>
                <child>
                  <object class="GtkToggleButton" id="tree_view_toggle">
                    <property name="action-name">dialog.view-mode</property>
                    <property name="action-target">&apos;tree&apos;</property>
                    <property name="icon-name">view-tree</property>
                    <property name="tooltip-text">Tree view</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="BrkButtonGroup">
                <child>
                  <object class="GtkToggleButton" id="show_binary_toggle">
                    <property name="action-name">dialog.show-binary</property>
                    <property name="label">01</property>
                    <property name="tooltip-text">Show binary files (Ctrl+B)</property>
                  </object>
                </child>
                <child>
                  <object class="GtkToggleButton" id="show_hidden_toggle">
                    <property name="action-name">dialog.show-hidden</property>
                    <property name="label">.h</property>
                    <property name="tooltip-text">Show hidden files (Ctrl+H)</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <property name="content">
          <object class="GtkPaned">
            <property name="focusable">false</property>
            <property name="hexpand">true</property>
            <property name="vexpand">true</property>
            <property name="shrink-start-child">false</property>
            <property name="resize-start-child">false</property>
            <property name="shrink-end-child">false</property>
            <property name="resize-end-child">true</property>
            <property name="start-child">
              <object class="GtkScrolledWindow">
                <property name="hscrollbar-policy">never</property>
                <style>
                  <class name="sidebar"/>
                </style>
                <child>
                  <object class="GtkListBox" id="sidebar_list_box">
                    <style>
                      <class name="navigation-sidebar"/>
                    </style>
                  </object>
                </child>
              </object>
            </property>
            <property name="end-child">
              <object class="GtkStack" id="view_stack">
                <property name="hexpand">true</property>
                <property name="vexpand">true</property>
                <child>
                  <object class="GtkStackPage">
                    <property name="child">
                      <object class="BrkFileDialogIconView" id="icon_view">
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="GtkStackPage">
                    <property name="child">
                      <object class="BrkFileDialogListView" id="list_view">
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="GtkStackPage">
                    <property name="child">
                      <object class="BrkFileDialogTreeView" id="tree_view">
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </property>
        <child type="bottom">
          <object class="GtkActionBar" id="open_bar">
            <child type="end">
              <object class="GtkButton">
                <property name="label">Cancel</property>
                <property name="action-name">window.close</property>
              </object>
            </child>
            <child type="end">
              <object class="GtkButton" id="open_button">
                <property name="label">Open</property>
                <property name="action-name">dialog.open</property>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
          </object>
        </child>
        <child type="bottom">
          <object class="GtkActionBar" id="save_bar">
            <child type="start">
              <object class="GtkBox">
                <property name="spacing">6</property>
                <property name="margin-start">6</property>
                <property name="margin-end">6</property>
                <child>
                  <object class="GtkLabel">
                    <property name="label" translatable="yes">Filename:</property>
                  </object>
                </child>
                <child>
                  <object class="GtkEntry" id="filename_entry">
                    <property name="width-request">240</property>
                    <property name="activates-default">true</property>
                  </object>
                </child>
              </object>
            </child>
            <child type="end">
              <object class="GtkButton">
                <property name="label">Cancel</property>
                <property name="action-name">window.close</property>
              </object>
            </child>
            <child type="end">
              <object class="GtkButton" id="save_button">
                <property name="label">Save</property>
                <property name="action-name">dialog.save</property>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>

